generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // App runtime
  directUrl = env("DIRECT_URL")     // Migrations / CI
}
enum PreorderStatus {
  pending
  confirmed
  delivered
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  phone         String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  fbclid        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  preorders     Preorder[]

  @@index([utmSource])
  @@index([utmCampaign])
}

model Preorder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quantity  Int      @default(1)
  status    PreorderStatus @default(pending)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  fbclid      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([utmSource])
  @@index([utmCampaign])
}
